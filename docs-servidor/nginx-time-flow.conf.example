# Ejemplo de configuración nginx para la app (SPA Vite)
# Copia a: /etc/nginx/sites-available/time-flow (o similar) y enlaza desde sites-enabled.
# Ajusta server_name y root con tu dominio y ruta.

server {
    listen 80;
    server_name gneraitiq.com www.gneraitiq.com;   # o la IP si no usas dominio
    root /var/www/time-flow-sapphire/dist;
    index index.html;

    # Archivos estáticos (JS, CSS, assets)
    location /assets {
        try_files $uri =404;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }
    location ~* \.(js|css|ico|png|jpg|jpeg|gif|svg|woff2?)$ {
        try_files $uri =404;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # SPA: todas las rutas sirven index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Opcional: redirigir HTTP a HTTPS si usas certificado
    # return 301 https://$server_name$request_uri;
}

